{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "elashes",
  "version": "0.1.0",
  "identifier": "com.ivan.elashes",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../server/public/app"
  },
  "app": {
    "windows": [
      {
        "title": "elashes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
