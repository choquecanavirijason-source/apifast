[Unit]
Description=Elashes Backend FastAPI
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/elashes/apifast/elashesbackend
EnvironmentFile=/opt/elashes/apifast/elashesbackend/.env
ExecStart=/opt/elashes/apifast/elashesbackend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
